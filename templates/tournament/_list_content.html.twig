{% for tournament in tournaments %}
    <div class="col-lg-4 col-md-6 mb-4">
        <div class="tournament-card">
            <div class="card-img-container">
                {% if tournament.posterPath %}
                    <img src="{{ tournament.posterPath }}" class="tournament-card-img" alt="Poster {{ tournament.name }}">
                {% else %}
                    <div class="tournament-card-img d-flex align-items-center justify-content-center bg-dark">
                        <i class="fas fa-gamepad fa-3x opacity-25"></i>
                    </div>
                {% endif %}
                
                <div class="card-badges">
                    <span class="game-badge">{{ tournament.game }}</span>
                    {% if not tournament.isActive %}
                        <span class="status-badge status-closed text-uppercase">Fermé</span>
                    {% elseif tournament.registrations|length >= tournament.maxTeams %}
                        <span class="status-badge status-closed text-uppercase" style="background: #ffc107; color: #000;">Plein</span>
                    {% else %}
                        <span class="status-badge status-active text-uppercase">Ouvert</span>
                    {% endif %}
                </div>

                {% if qrCodes[tournament.id] is defined %}
                    <a href="{{ path('app_tournament_register', {'id': tournament.id}) }}" class="qr-code-overlay" title="Cliquez ou scannez pour vous inscrire">
                        <img src="{{ qrCodes[tournament.id] }}" alt="QR Code" class="qr-code-img">
                        <div class="qr-code-label">SCAN OR CLICK</div>
                    </a>
                {% endif %}
            </div>

            <div class="tournament-content">
                <h3 class="tournament-title">{{ tournament.name }}</h3>
                
                <div class="tournament-info">
                    <i class="far fa-calendar-alt text-danger"></i>
                    {{ tournament.startDate|date('d/m/Y') }} – {{ tournament.endDate|date('d/m/Y') }}
                </div>

                <div class="tournament-info">
                    <i class="fas fa-layer-group text-danger"></i>
                    {{ tournament.phase }}
                </div>
                
                <div class="tournament-actions">
                    <a href="{{ path('app_tournament_detail', {'id': tournament.id}) }}" class="btn-view">VOIR PLUS</a>
                    
                    <a href="{{ path('app_tournament_edit', {'id': tournament.id}) }}" class="btn-action" title="Modifier">
                        <i class="fas fa-edit"></i>
                    </a>
                    
                    <form method="post" action="{{ path('app_tournament_toggle', {'id': tournament.id}) }}" style="display:inline-block;">
                        <button class="btn-action">
                            <i class="fas {% if tournament.isActive %}fa-eye-slash{% else %}fa-eye{% endif %}"></i>
                        </button>
                    </form>

                    <form method="post" action="{{ path('app_tournament_delete', {'id': tournament.id}) }}" onsubmit="return confirm('Supprimer ce tournoi ?');" style="display:inline-block;">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ tournament.id) }}">
                        <button class="btn-action">
                            <i class="fas fa-trash-alt"></i>
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
{% else %}
    <div class="col-12 text-center py-5">
        <div class="pf-card">
            <p class="text-muted mb-0">Aucun tournoi trouvé pour ces critères.</p>
        </div>
    </div>
{% endfor %}
