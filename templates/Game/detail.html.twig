{% extends 'base.html.twig' %}

{% block title %}{{ game.name }} - Phantom Shop{% endblock %}

{% block body %}
<div class="container">
    <div class="game-detail">
        <div class="back-link">
            <a href="{{ path('app_games_popular') }}" class="back-btn">
                <i class="fas fa-arrow-left"></i> Retour aux jeux
            </a>
        </div>
        
        <div class="game-header">
            <h1>{{ game.name }}</h1>
            {% if game.rating %}
                <div class="rating-large">
                    <i class="fas fa-star"></i>
                    <span>{{ game.rating }}</span>
                    <small>/5</small>
                </div>
            {% endif %}
        </div>
        
        <div class="game-content">
            <div class="game-image-large">
                {% if game.background_image %}
                    <img src="{{ game.background_image }}" alt="{{ game.name }}">
                {% endif %}
            </div>
            
            <div class="game-details">
                <div class="detail-card">
                    <h3>Description</h3>
                    <p>{{ game.description_raw|default('Description non disponible') }}</p>
                </div>
                
                <div class="detail-card">
                    <h3>Informations</h3>
                    <ul class="info-list">
                        <li><strong>Date de sortie:</strong> {{ game.released|date('d/m/Y') }}</li>
                        {% if game.developers %}
                            <li><strong>Développeurs:</strong> 
                                {% for dev in game.developers %}
                                    {{ dev.name }}{% if not loop.last %}, {% endif %}
                                {% endfor %}
                            </li>
                        {% endif %}
                        {% if game.publishers %}
                            <li><strong>Éditeurs:</strong>
                                {% for pub in game.publishers %}
                                    {{ pub.name }}{% if not loop.last %}, {% endif %}
                                {% endfor %}
                            </li>
                        {% endif %}
                        {% if game.genres %}
                            <li><strong>Genres:</strong>
                                {% for genre in game.genres %}
                                    {{ genre.name }}{% if not loop.last %}, {% endif %}
                                {% endfor %}
                            </li>
                        {% endif %}
                        {% if game.platforms %}
                            <li><strong>Plateformes:</strong>
                                {% for platform in game.platforms|slice(0, 5) %}
                                    {{ platform.platform.name }}{% if not loop.last %}, {% endif %}
                                {% endfor %}
                            </li>
                        {% endif %}
                    </ul>
                </div>
                
                <div class="detail-card">
                    <h3>Métacritique</h3>
                    {% if game.metacritic %}
                        <div class="metacritic-score">{{ game.metacritic }}</div>
                    {% else %}
                        <p>Non disponible</p>
                    {% endif %}
                </div>
                
                <div class="purchase-box">
                    <div class="price">Prix: 59.99 €</div>
                    <a href="{{ path('app_payment_new', {'game_id': game.id}) }}" class="btn-buy-large">
                        <i class="fas fa-shopping-cart"></i> Acheter maintenant
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
.back-link {
    margin-bottom: 20px;
}

.back-btn {
    color: var(--text-muted);
    text-decoration: none;
    transition: var(--transition);
}

.back-btn:hover {
    color: var(--red);
}

.game-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 30px;
    padding: 20px 0;
    border-bottom: 2px solid var(--red);
}

.game-header h1 {
    margin: 0;
}

.rating-large {
    color: #ffd700;
    font-size: 24px;
    font-weight: 700;
}

.game-content {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 30px;
}

.game-image-large img {
    width: 100%;
    border-radius: 10px;
    box-shadow: var(--shadow);
}

.detail-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 20px;
    margin-bottom: 20px;
}

.detail-card h3 {
    color: var(--red);
    margin-bottom: 15px;
}

.info-list {
    list-style: none;
    padding: 0;
}

.info-list li {
    margin-bottom: 10px;
}

.metacritic-score {
    font-size: 48px;
    font-weight: 800;
    color: var(--neon-green);
}

.purchase-box {
    background: linear-gradient(135deg, rgba(255,45,45,0.2), rgba(255,45,45,0.05));
    border: 2px solid var(--red);
    border-radius: 10px;
    padding: 20px;
    text-align: center;
}

.price {
    font-size: 32px;
    font-weight: 800;
    color: var(--neon-green);
    margin-bottom: 20px;
}

.btn-buy-large {
    display: inline-block;
    padding: 15px 40px;
    background: var(--red-gradient);
    color: white;
    text-decoration: none;
    border-radius: 8px;
    font-weight: 700;
    transition: var(--transition);
}

.btn-buy-large:hover {
    transform: translateY(-3px);
    box-shadow: 0 5px 20px rgba(255,45,45,0.4);
}

@media (max-width: 768px) {
    .game-content {
        grid-template-columns: 1fr;
    }
}
</style>
{% if recommendations|length > 0 %}
<div class="recommendations">
    <h3>🤖 Recommandé pour vous</h3>
    <div class="rec-list">
        {% for rec in recommendations %}
            <div class="rec-item">
                <strong>{{ rec.name }}</strong>
                <p>{{ rec.reason }}</p>
            </div>
        {% endfor %}
    </div>
</div>
{% endif %}

{% if ai_description %}
<div class="ai-description">
    <h3>✨ Description générée par IA</h3>
    <p>{{ ai_description }}</p>
</div>
{% endif %}
{% endblock %}