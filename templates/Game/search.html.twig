{% extends 'base.html.twig' %}

{% block title %}Recherche de jeux - Phantom Shop{% endblock %}

{% block body %}
<div class="container">
    <div class="hero">
        <h1>🔍 Recherche de jeux</h1>
        <p>Trouvez le jeu qui vous correspond</p>
    </div>
    
    <div class="search-section">
        <form action="{{ path('app_games_search') }}" method="get" class="search-form">
            <input type="text" name="q" value="{{ search }}" placeholder="Nom du jeu..." class="search-input" autofocus>
            <button type="submit" class="search-btn">
                <i class="fas fa-search"></i> Rechercher
            </button>
        </form>
    </div>
    
    {% if search %}
        <div class="results-info">
            <h2>Résultats pour "{{ search }}"</h2>
            <p>{{ games|length }} jeu(x) trouvé(s)</p>
        </div>
        
        <div class="games-grid">
            {% for game in games %}
                <div class="game-card">
                    {% if game.background_image %}
                        <img src="{{ game.background_image }}" alt="{{ game.name }}" class="game-image">
                    {% else %}
                        <div class="game-image-placeholder">
                            <i class="fas fa-gamepad"></i>
                        </div>
                    {% endif %}
                    
                    <div class="game-info">
                        <h3>{{ game.name }}</h3>
                        
                        <div class="game-meta">
                            <span class="rating">
                                <i class="fas fa-star"></i> 
                                {{ game.rating|default('N/A') }}
                            </span>
                            <span class="released">{{ game.released|date('d/m/Y') }}</span>
                        </div>
                        
                        <div class="game-actions">
                            <a href="{{ path('app_game_detail', {'id': game.id}) }}" class="btn-view">
                                <i class="fas fa-info-circle"></i> Détails
                            </a>
                            <a href="{{ path('app_payment_new', {'game_id': game.id}) }}" class="btn-buy">
                                <i class="fas fa-shopping-cart"></i> Acheter
                            </a>
                        </div>
                    </div>
                </div>
            {% else %}
                <div class="no-results">
                    <i class="fas fa-frown"></i>
                    <p>Aucun jeu trouvé pour "{{ search }}"</p>
                    <a href="{{ path('app_games_popular') }}" class="btn-back">
                        Voir les jeux populaires
                    </a>
                </div>
            {% endfor %}
        </div>
    {% endif %}
</div>

<style>
.search-section {
    margin: 30px 0;
    display: flex;
    justify-content: center;
}

.search-form {
    display: flex;
    gap: 10px;
    width: 100%;
    max-width: 600px;
}

.search-input {
    flex: 1;
    padding: 15px 20px;
    background: rgba(255,255,255,0.05);
    border: 2px solid var(--border);
    border-radius: 8px;
    color: white;
    font-size: 16px;
}

.search-input:focus {
    outline: none;
    border-color: var(--red);
}

.search-btn {
    padding: 15px 30px;
    background: var(--red-gradient);
    border: none;
    border-radius: 8px;
    color: white;
    font-weight: 600;
    cursor: pointer;
    transition: var(--transition);
}

.search-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 5px 15px rgba(255,45,45,0.3);
}

.results-info {
    text-align: center;
    margin: 30px 0;
}

.games-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 20px;
    margin-top: 20px;
}

.game-card {
    background: var(--bg-card);
    border: 2px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
    transition: var(--transition);
}

.game-card:hover {
    transform: translateY(-5px);
    border-color: var(--red);
}

.game-image {
    width: 100%;
    height: 160px;
    object-fit: cover;
}

.game-image-placeholder {
    width: 100%;
    height: 160px;
    background: linear-gradient(135deg, #2a2a35, #1a1a25);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 40px;
    color: var(--red);
}

.game-info {
    padding: 15px;
}

.game-info h3 {
    font-size: 16px;
    margin-bottom: 10px;
}

.game-meta {
    display: flex;
    justify-content: space-between;
    margin-bottom: 15px;
    font-size: 13px;
}

.rating {
    color: #ffd700;
}

.released {
    color: var(--text-muted);
}

.game-actions {
    display: flex;
    gap: 10px;
}

.btn-view, .btn-buy {
    flex: 1;
    padding: 8px;
    border-radius: 6px;
    text-decoration: none;
    font-size: 12px;
    font-weight: 600;
    text-align: center;
}

.btn-view {
    background: rgba(255,255,255,0.05);
    border: 1px solid var(--border);
    color: var(--text-light);
}

.btn-buy {
    background: var(--red-gradient);
    color: white;
}

.no-results {
    grid-column: 1 / -1;
    text-align: center;
    padding: 60px;
    color: var(--text-muted);
}

.no-results i {
    font-size: 60px;
    color: var(--red);
    margin-bottom: 20px;
}

.btn-back {
    display: inline-block;
    margin-top: 20px;
    padding: 12px 25px;
    background: var(--red-gradient);
    color: white;
    text-decoration: none;
    border-radius: 8px;
}
</style>
{% endblock %}