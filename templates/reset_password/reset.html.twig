{% extends 'base.html.twig' %}

{% block title %}Reset your password{% endblock %}

{% block body %}
    <div class="cyber-card reset-password-card">
        <div class="cyber-card-header">
            <h1 class="cyber-title">
                <span class="title-glitch">NEW</span>
                <span class="title-glitch">CREDENTIALS</span>
            </h1>
            <div class="header-scanline"></div>
        </div>

        <div class="cyber-card-body">
            <div class="security-notice">
                <div class="notice-content">
                    <span class="notice-icon">🔒</span>
                    <span class="notice-text">SECURE CONNECTION ESTABLISHED</span>
                </div>
                <div class="security-level">
                    <span class="level-bar"></span>
                    <span class="level-bar"></span>
                    <span class="level-bar"></span>
                    <span class="level-text">TLS 1.3</span>
                </div>
            </div>

            <div class="reset-form-container">
                {{ form_start(resetForm, {'attr': {'class': 'cyber-form'}}) }}
                    
                    <div class="form-field">
                        <div class="field-label">
                            <span class="label-icon">⌂</span>
                            <span class="label-text">NEW ACCESS CODE</span>
                        </div>
                        
                        <div class="field-input-wrapper">
                            {{ form_widget(resetForm.plainPassword, {
                                'attr': {
                                    'class': 'cyber-input',
                                    'placeholder': 'Enter new password'
                                }
                            }) }}
                            <div class="input-border"></div>
                        </div>
                        
                        {% if form_errors(resetForm.plainPassword) %}
                            <div class="field-error">
                                <span class="error-icon">⚠</span>
                                {{ form_errors(resetForm.plainPassword) }}
                            </div>
                        {% endif %}
                    </div>

                    <div class="password-requirements">
                        <div class="requirements-header">
                            <span class="requirements-icon">⚡</span>
                            <span class="requirements-title">SECURITY PROTOCOLS</span>
                        </div>
                        <ul class="requirements-list">
                            <li class="requirement-item">
                                <span class="requirement-bullet">▶</span>
                                <span class="requirement-text">Minimum 8 characters</span>
                            </li>
                            <li class="requirement-item">
                                <span class="requirement-bullet">▶</span>
                                <span class="requirement-text">At least one number</span>
                            </li>
                            <li class="requirement-item">
                                <span class="requirement-bullet">▶</span>
                                <span class="requirement-text">One uppercase letter</span>
                            </li>
                            <li class="requirement-item">
                                <span class="requirement-bullet">▶</span>
                                <span class="requirement-text">Special character recommended</span>
                            </li>
                        </ul>
                    </div>

                    <div class="form-actions">
                        <button type="submit" class="cyber-btn cyber-btn-primary">
                            <span class="btn-text">INITIALIZE RESET</span>
                            <span class="btn-icon">⚡</span>
                        </button>
                        
                        <a href="{{ path('app_login') }}" class="cyber-btn cyber-btn-secondary">
                            <span class="btn-text">CANCEL</span>
                            <span class="btn-icon">✗</span>
                        </a>
                    </div>
                {{ form_end(resetForm) }}
            </div>
        </div>

        <div class="cyber-card-footer">
            <div class="footer-stats">
                <span class="stat">STATUS: <span class="stat-value">AWAITING NEW CODE</span></span>
                <span class="stat">ENCRYPTION: <span class="stat-value">ACTIVE</span></span>
            </div>
            <div class="footer-corner"></div>
        </div>
    </div>

    <style>
        .cyber-card {
            background: linear-gradient(145deg, rgba(17,17,17,0.95) 0%, rgba(34,34,34,0.95) 100%);
            border: 1px solid rgba(255,0,60,0.3);
            box-shadow: 0 20px 40px rgba(0,0,0,0.8), 0 0 30px rgba(255,0,0,0.2);
            position: relative;
            overflow: hidden;
            backdrop-filter: blur(10px);
            margin: 40px auto;
            max-width: 600px;
        }

        .cyber-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 50%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255,0,60,0.1), transparent);
            transform: skewX(-25deg);
            animation: cardShine 3s infinite;
        }

        @keyframes cardShine {
            0% { left: -100%; }
            20% { left: 150%; }
            100% { left: 150%; }
        }

        .cyber-card-header {
            padding: 30px 30px 20px;
            border-bottom: 2px solid rgba(255,0,60,0.3);
            position: relative;
        }

        .cyber-title {
            font-family: 'Aldrich', sans-serif;
            font-size: 2.2em;
            text-transform: uppercase;
            margin: 0;
            line-height: 1.2;
            position: relative;
            display: inline-block;
        }

        .title-glitch {
            display: block;
            color: transparent;
            background: linear-gradient(45deg, #fff, #ff003c, #ff0000);
            -webkit-background-clip: text;
            background-clip: text;
            text-shadow: 0 0 20px rgba(255,0,60,0.5);
            animation: glitch 3s infinite;
        }

        .title-glitch:nth-child(2) {
            font-size: 0.8em;
            opacity: 0.8;
            margin-top: 5px;
        }

        @keyframes glitch {
            0%, 100% { transform: skew(0deg, 0deg); opacity: 1; }
            95% { transform: skew(0deg, 0deg); opacity: 1; }
            96% { transform: skew(5deg, 0deg); opacity: 0.8; }
            97% { transform: skew(-5deg, 0deg); opacity: 0.9; }
            98% { transform: skew(3deg, 0deg); opacity: 0.8; }
        }

        .header-scanline {
            position: absolute;
            bottom: 0;
            left: 0;
            width: 100%;
            height: 2px;
            background: linear-gradient(90deg, transparent, #ff003c, transparent);
            animation: scanline 2s linear infinite;
        }

        @keyframes scanline {
            0% { transform: translateX(-100%); }
            100% { transform: translateX(100%); }
        }

        .cyber-card-body {
            padding: 30px;
        }

        .security-notice {
            background: rgba(0,255,0,0.05);
            border: 1px solid rgba(0,255,0,0.2);
            padding: 15px 20px;
            margin-bottom: 25px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            animation: glowPulse 2s infinite;
        }

        @keyframes glowPulse {
            0%, 100% { box-shadow: 0 0 10px rgba(0,255,0,0.1); }
            50% { box-shadow: 0 0 20px rgba(0,255,0,0.2); }
        }

        .notice-content {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .notice-icon {
            font-size: 1.2em;
            filter: drop-shadow(0 0 5px #00ff00);
        }

        .notice-text {
            color: #00ff00;
            font-family: 'Aldrich', monospace;
            font-size: 0.8em;
            letter-spacing: 2px;
        }

        .security-level {
            display: flex;
            align-items: center;
            gap: 5px;
        }

        .level-bar {
            width: 20px;
            height: 6px;
            background: rgba(0,255,0,0.2);
            position: relative;
            overflow: hidden;
        }

        .level-bar::after {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: #00ff00;
            animation: levelFill 2s ease-out forwards;
        }

        @keyframes levelFill {
            from { width: 0; }
            to { width: 100%; }
        }

        .level-text {
            color: #00ff00;
            font-size: 0.7em;
            margin-left: 5px;
        }

        .cyber-form {
            display: flex;
            flex-direction: column;
            gap: 25px;
        }

        .form-field {
        position: relative;
    }

    .field-label {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 10px;
        font-family: 'Orbitron', sans-serif;
        font-size: 0.8em;
        color: #999;
        text-transform: uppercase;
        letter-spacing: 2px;
    }

    .label-icon {
        color: #ff003c;
    }

    /* ULTRA-SPECIFIC INPUT STYLES - These will override everything */
    .field-input-wrapper {
        position: relative;
        background: #000000 !important;
        border: 2px solid #ff003c !important;
        border-radius: 4px !important;
        padding: 0 !important;
        box-shadow: 0 0 15px rgba(255, 0, 60, 0.3) !important;
        transition: all 0.3s ease;
    }

    .field-input-wrapper:focus-within {
        border-color: #ff0066 !important;
        box-shadow: 0 0 25px rgba(255, 0, 102, 0.6) !important;
        transform: scale(1.02);
    }

    /* Target EVERY possible input variation */
    .field-input-wrapper input,
    .field-input-wrapper input[type="password"],
    .field-input-wrapper .cyber-input,
    .field-input-wrapper input.form-control,
    .field-input-wrapper #reset_form_plainPassword,
    input#reset_form_plainPassword {
        background: #0a0a0a !important;
        border: none !important;
        border-radius: 3px !important;
        color: #ffffff !important;
        width: 100% !important;
        padding: 15px 20px !important;
        font-family: 'Rajdhani', sans-serif !important;
        font-size: 1.1em !important;
        margin: 0 !important;
        box-sizing: border-box !important;
        outline: none !important;
        -webkit-appearance: none !important;
        -moz-appearance: none !important;
        appearance: none !important;
        box-shadow: none !important;
    }

    .field-input-wrapper input:focus,
    .field-input-wrapper input[type="password"]:focus,
    .field-input-wrapper .cyber-input:focus,
    .field-input-wrapper input.form-control:focus,
    .field-input-wrapper #reset_form_plainPassword:focus,
    input#reset_form_plainPassword:focus {
        background: #111111 !important;
        border: none !important;
        box-shadow: none !important;
        outline: none !important;
    }

    .field-input-wrapper input::placeholder,
    .field-input-wrapper input[type="password"]::placeholder,
    .field-input-wrapper .cyber-input::placeholder {
        color: rgba(255, 255, 255, 0.4) !important;
        font-style: italic;
        opacity: 1 !important;
    }

    .field-input-wrapper::after {
        content: '▌';
        position: absolute;
        right: 15px;
        top: 50%;
        transform: translateY(-50%);
        color: #ff003c;
        font-size: 1.4em;
        opacity: 0;
        transition: opacity 0.3s;
        pointer-events: none;
        z-index: 1000;
    }

    .field-input-wrapper:focus-within::after {
        opacity: 1;
        animation: blink 1s infinite;
    }

    @keyframes blink {
        0%, 100% { opacity: 1; }
        50% { opacity: 0; }
    }

    .input-border {
        position: absolute;
        bottom: 0;
        left: 0;
        width: 0;
        height: 3px;
        background: #ff003c;
        box-shadow: 0 0 10px #ff003c;
        transition: width 0.3s ease;
        z-index: 1001;
    }

    .field-input-wrapper:focus-within .input-border {
        width: 100%;
        background: linear-gradient(90deg, #ff003c, #9d00ff);
        box-shadow: 0 0 15px #ff003c, 0 0 30px #9d00ff;
    }

    /* Remove any potential white backgrounds from the form theme */
    .cyber-form input,
    .cyber-form input[type="password"],
    .cyber-form .form-control {
        background-color: transparent !important;
    }

    /* All your remaining styles stay exactly the same */
    .field-error {
        margin-top: 8px;
        padding: 8px 12px;
        background: rgba(255,0,0,0.1);
        border: 1px solid rgba(255,0,0,0.3);
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 0.9em;
        color: #ff6666;
    }

    .error-icon {
        color: #ff0000;
    }

    .password-requirements {
        background: rgba(0,0,0,0.5);
        border: 1px solid rgba(255,0,60,0.2);
        padding: 20px;
    }

    .requirements-header {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 15px;
    }

    .requirements-icon {
        color: #ff003c;
        font-size: 1.2em;
    }

    .requirements-title {
        font-family: 'Orbitron', sans-serif;
        font-size: 0.8em;
        color: #666;
        letter-spacing: 2px;
    }

    .requirements-list {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .requirement-item {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 8px 0;
        border-bottom: 1px solid rgba(255,255,255,0.05);
    }

    .requirement-item:last-child {
        border-bottom: none;
    }

    .requirement-bullet {
        color: #ff003c;
        font-size: 0.8em;
    }

    .requirement-text {
        color: #ccc;
        font-family: 'Rajdhani', sans-serif;
        font-size: 0.9em;
    }

    .form-actions {
        display: flex;
        gap: 15px;
        margin-top: 10px;
    }

    .cyber-btn {
        flex: 1;
        padding: 15px 25px;
        border: none;
        font-family: 'Orbitron', sans-serif;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 2px;
        cursor: pointer;
        position: relative;
        overflow: hidden;
        transition: all 0.3s;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        font-size: 0.9em;
    }

    .cyber-btn-primary {
        background: linear-gradient(45deg, #8b0000, #ff003c);
        color: white;
        box-shadow: 0 0 20px rgba(255,0,60,0.3);
    }

    .cyber-btn-secondary {
        background: linear-gradient(45deg, #333333, #555555);
        color: #ccc;
    }

    .cyber-btn::before {
        content: '';
        position: absolute;
        top: 0;
        left: -100%;
        width: 100%;
        height: 100%;
        background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
        transition: 0.5s;
    }

    .cyber-btn:hover {
        transform: translateY(-2px);
    }

    .cyber-btn-primary:hover {
        box-shadow: 0 0 30px rgba(255,0,60,0.5);
    }

    .cyber-btn-secondary:hover {
        background: linear-gradient(45deg, #444444, #666666);
    }

    .cyber-btn:hover::before {
        left: 100%;
    }

    .btn-icon {
        font-size: 1.2em;
        transition: transform 0.3s;
    }

    .cyber-btn:hover .btn-icon {
        transform: translateX(5px) scale(1.2);
    }

    .cyber-card-footer {
        padding: 20px 30px;
        border-top: 1px solid rgba(255,0,60,0.2);
        position: relative;
    }

    .footer-stats {
        display: flex;
        justify-content: space-between;
        font-family: 'Aldrich', monospace;
        font-size: 0.8em;
    }

    .stat {
        color: #666;
    }

    .stat-value {
        color: #ff003c;
        margin-left: 5px;
    }

    .footer-corner {
        position: absolute;
        bottom: 0;
        right: 0;
        width: 30px;
        height: 30px;
        border-bottom: 2px solid #ff003c;
        border-right: 2px solid #ff003c;
    }

    @media (max-width: 768px) {
        .cyber-card {
            margin: 20px;
        }
        
        .cyber-title {
            font-size: 1.5em;
        }
        
        .form-actions {
            flex-direction: column;
        }
        
        .security-notice {
            flex-direction: column;
            gap: 10px;
            text-align: center;
        }
        
        .footer-stats {
            flex-direction: column;
            gap: 5px;
        }
    }
    </style>
{% endblock %}