{% extends 'base.html.twig' %}

{% block title %}Analyste Esport Pro - Dashboard IA{% endblock %}

{% block stylesheets %}
<style>
    :root {
        --esport-gradient: linear-gradient(135deg, #ff2d2d, #ff5e5e, #ff8a8a);
        --analyst-card-bg: rgba(20,20,30,0.9);
    }

    .analyst-hero {
        text-align: center;
        padding: 60px 20px;
        background: linear-gradient(135deg, rgba(255,45,45,0.2), rgba(0,0,0,0));
        border-radius: var(--radius-lg);
        margin-bottom: 50px;
        position: relative;
        overflow: hidden;
    }

    .analyst-hero::before {
        content: '';
        position: absolute;
        top: -50%;
        left: -50%;
        width: 200%;
        height: 200%;
        background: radial-gradient(circle, rgba(255,45,45,0.2) 0%, transparent 70%);
        animation: rotate 30s linear infinite;
    }

    .analyst-hero h1 {
        font-size: 52px;
        font-weight: 800;
        margin-bottom: 20px;
        background: linear-gradient(135deg, #fff, var(--red));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        position: relative;
    }

    .analyst-hero p {
        font-size: 18px;
        color: var(--text-muted);
        max-width: 700px;
        margin: 0 auto;
        position: relative;
    }

    .stats-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 25px;
        margin: 40px 0;
    }

    .stat-card-premium {
        background: var(--analyst-card-bg);
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        padding: 30px 20px;
        text-align: center;
        backdrop-filter: blur(10px);
        transition: var(--transition);
        position: relative;
        overflow: hidden;
    }

    .stat-card-premium::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 3px;
        background: var(--esport-gradient);
        animation: borderFlow 3s linear infinite;
    }

    .stat-card-premium:hover {
        transform: translateY(-10px);
        box-shadow: var(--shadow-lg);
    }

    .stat-icon-premium {
        width: 60px;
        height: 60px;
        background: var(--red-soft);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 20px;
        font-size: 24px;
        color: var(--red);
    }

    .stat-value-premium {
        font-size: 36px;
        font-weight: 800;
        margin-bottom: 5px;
        background: linear-gradient(135deg, #fff, var(--red));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .stat-label-premium {
        color: var(--text-muted);
        font-size: 14px;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .search-section {
        background: var(--analyst-card-bg);
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        padding: 40px;
        margin: 50px 0;
        backdrop-filter: blur(10px);
    }

    .search-title {
        font-size: 24px;
        font-weight: 700;
        margin-bottom: 30px;
        text-align: center;
    }

    .search-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 20px;
    }

    .search-card {
        background: rgba(255,255,255,0.03);
        border: 1px solid var(--border-light);
        border-radius: var(--radius);
        padding: 25px;
        text-align: center;
        transition: var(--transition);
        cursor: pointer;
    }

    .search-card:hover {
        border-color: var(--red);
        transform: scale(1.05);
        background: rgba(255,45,45,0.05);
    }

    .search-icon {
        width: 50px;
        height: 50px;
        background: var(--red-soft);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 15px;
        color: var(--red);
        font-size: 20px;
    }

    .live-analysis-panel {
        background: var(--analyst-card-bg);
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        padding: 30px;
        margin: 50px 0;
    }

    .live-header {
        display: flex;
        align-items: center;
        gap: 15px;
        margin-bottom: 30px;
    }

    .live-dot {
        width: 12px;
        height: 12px;
        background: var(--red);
        border-radius: 50%;
        animation: pulse 1.5s infinite;
    }

    .live-title {
        font-size: 20px;
        font-weight: 700;
    }

    .live-badge {
        background: var(--red);
        color: white;
        padding: 5px 15px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 600;
        margin-left: auto;
    }

    .live-match-card {
        display: grid;
        grid-template-columns: 1fr auto 1fr;
        gap: 30px;
        align-items: center;
        background: rgba(0,0,0,0.3);
        border-radius: var(--radius);
        padding: 25px;
        margin-bottom: 20px;
    }

    .live-team {
        text-align: center;
    }

    .live-team-logo {
        width: 60px;
        height: 60px;
        background: var(--red-soft);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 10px;
        font-size: 20px;
        font-weight: 700;
    }

    .live-team-name {
        font-weight: 600;
        margin-bottom: 5px;
    }

    .live-score {
        font-size: 32px;
        font-weight: 800;
        color: var(--red);
    }

    .live-progress {
        text-align: center;
    }

    .progress-bar-container {
        width: 200px;
        height: 8px;
        background: rgba(255,255,255,0.1);
        border-radius: 4px;
        margin: 10px auto;
        overflow: hidden;
    }

    .progress-bar-fill {
        height: 100%;
        background: var(--red-gradient);
        width: 65%;
        border-radius: 4px;
        animation: widthGrow 1s ease-out;
    }

    .features-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 30px;
        margin-top: 50px;
    }

    .feature-card {
        background: var(--analyst-card-bg);
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        padding: 30px;
        transition: var(--transition);
    }

    .feature-card:hover {
        transform: translateY(-5px);
        border-color: var(--red);
    }

    .feature-header {
        display: flex;
        align-items: center;
        gap: 15px;
        margin-bottom: 20px;
    }

    .feature-header i {
        font-size: 30px;
        color: var(--red);
    }

    .feature-header h3 {
        font-size: 20px;
        font-weight: 700;
    }

    .feature-list {
        list-style: none;
        padding: 0;
    }

    .feature-list li {
        padding: 10px 0;
        border-bottom: 1px solid var(--border-light);
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .feature-list li i {
        color: var(--green);
        font-size: 14px;
    }

    .back-link {
        display: inline-block;
        margin-bottom: 20px;
        color: var(--text-muted);
        text-decoration: none;
        transition: var(--transition);
    }

    .back-link:hover {
        color: var(--red);
        transform: translateX(-5px);
    }

    @media (max-width: 1200px) {
        .stats-grid {
            grid-template-columns: repeat(2, 1fr);
        }
        
        .search-grid {
            grid-template-columns: repeat(2, 1fr);
        }
        
        .features-grid {
            grid-template-columns: 1fr;
        }
    }

    @media (max-width: 768px) {
        .stats-grid,
        .search-grid {
            grid-template-columns: 1fr;
        }
        
        .live-match-card {
            grid-template-columns: 1fr;
            text-align: center;
        }
        
        .analyst-hero h1 {
            font-size: 32px;
        }
    }
</style>
{% endblock %}

{% block body %}
<a href="{{ path('app_ai') }}" class="back-link">
    <i class="fas fa-arrow-left"></i> Retour à l'accueil IA
</a>

<div class="analyst-hero">
    <h1>🎮 Analyste Esport Professionnel</h1>
    <p>Analyse avancée de joueurs, équipes et matchs en temps réel avec intelligence artificielle</p>
</div>

<div class="stats-grid">
    <div class="stat-card-premium">
        <div class="stat-icon-premium">
            <i class="fas fa-users"></i>
        </div>
        <div class="stat-value-premium">1,247</div>
        <div class="stat-label-premium">Joueurs analysés</div>
    </div>
    <div class="stat-card-premium">
        <div class="stat-icon-premium">
            <i class="fas fa-trophy"></i>
        </div>
        <div class="stat-value-premium">342</div>
        <div class="stat-label-premium">Équipes suivies</div>
    </div>
    <div class="stat-card-premium">
        <div class="stat-icon-premium">
            <i class="fas fa-chart-line"></i>
        </div>
        <div class="stat-value-premium">5,891</div>
        <div class="stat-label-premium">Matchs analysés</div>
    </div>
    <div class="stat-card-premium">
        <div class="stat-icon-premium">
            <i class="fas fa-microchip"></i>
        </div>
        <div class="stat-value-premium">GPT-4</div>
        <div class="stat-label-premium">Moteur IA</div>
    </div>
</div>

<div class="search-section">
    <h2 class="search-title">🔍 Recherche d'analyse</h2>
    <div class="search-grid">
        <form action="{{ path('app_analyst_player_search') }}" method="GET" style="display: contents;">
            <div class="search-card" onclick="this.closest('form').submit()">
                <div class="search-icon">
                    <i class="fas fa-user"></i>
                </div>
                <h3>Analyser un joueur</h3>
                <p style="color: var(--text-muted); font-size: 13px; margin-top: 10px;">Statistiques, forces, faiblesses, progression</p>
                <input type="text" name="playerName" placeholder="Nom du joueur" style="display: none;" value="Faker">
                <input type="hidden" name="game" value="league_of_legends">
            </div>
        </form>
        
        <form action="{{ path('app_analyst_team_search') }}" method="GET" style="display: contents;">
            <div class="search-card" onclick="this.closest('form').submit()">
                <div class="search-icon">
                    <i class="fas fa-users"></i>
                </div>
                <h3>Analyser une équipe</h3>
                <p style="color: var(--text-muted); font-size: 13px; margin-top: 10px;">Synergie, stratégies, drafts, performances</p>
                <input type="text" name="teamName" placeholder="Nom de l'équipe" style="display: none;" value="T1">
                <input type="hidden" name="game" value="league_of_legends">
            </div>
        </form>
        
        <div class="search-card" onclick="window.location.href='{{ path('app_analyst_live') }}'">
            <div class="search-icon">
                <i class="fas fa-broadcast-tower"></i>
            </div>
            <h3>Matchs en direct</h3>
            <p style="color: var(--text-muted); font-size: 13px; margin-top: 10px;">Analyse temps réel, prédictions live</p>
        </div>
    </div>
</div>

<div class="live-analysis-panel">
    <div class="live-header">
        <div class="live-dot"></div>
        <div class="live-title">Matchs en direct - Analyse temps réel</div>
        <div class="live-badge">LIVE</div>
    </div>
    
    <div class="live-match-card">
        <div class="live-team">
            <div class="live-team-logo">T1</div>
            <div class="live-team-name">T1</div>
            <div style="font-size: 12px; color: var(--text-muted);">LCK #1</div>
        </div>
        <div class="live-progress">
            <div class="live-score">12 - 8</div>
            <div class="progress-bar-container">
                <div class="progress-bar-fill" style="width: 65%;"></div>
            </div>
            <div style="font-size: 12px; color: var(--text-muted); margin-top: 5px;">65% win prob.</div>
        </div>
        <div class="live-team">
            <div class="live-team-logo">GEN</div>
            <div class="live-team-name">Gen.G</div>
            <div style="font-size: 12px; color: var(--text-muted);">LCK #2</div>
        </div>
    </div>
    
    <div style="text-align: center; margin-top: 20px;">
        <a href="{{ path('app_analyst_live') }}" class="btn btn-primary">
            <i class="fas fa-eye"></i> Voir tous les matchs en direct
        </a>
    </div>
</div>

<div class="features-grid">
    <div class="feature-card">
        <div class="feature-header">
            <i class="fas fa-chart-bar"></i>
            <h3>Analyse approfondie</h3>
        </div>
        <ul class="feature-list">
            <li><i class="fas fa-check"></i> KDA, CS/min, vision score</li>
            <li><i class="fas fa-check"></i> Heatmaps de déplacement</li>
            <li><i class="fas fa-check"></i> Analyse de décisions</li>
            <li><i class="fas fa-check"></i> Comparaison avec pros</li>
            <li><i class="fas fa-check"></i> Projections de progression</li>
        </ul>
    </div>
    
    <div class="feature-card">
        <div class="feature-header">
            <i class="fas fa-robot"></i>
            <h3>IA Prédictive</h3>
        </div>
        <ul class="feature-list">
            <li><i class="fas fa-check"></i> Prédictions de matchs</li>
            <li><i class="fas fa-check"></i> Analyse de drafts</li>
            <li><i class="fas fa-check"></i> Détection de patterns</li>
            <li><i class="fas fa-check"></i> Recommandations stratégiques</li>
            <li><i class="fas fa-check"></i> Alertes en temps réel</li>
        </ul>
    </div>
    
    <div class="feature-card">
        <div class="feature-header">
            <i class="fas fa-file-alt"></i>
            <h3>Rapports professionnels</h3>
        </div>
        <ul class="feature-list">
            <li><i class="fas fa-check"></i> Export PDF personnalisé</li>
            <li><i class="fas fa-check"></i> Graphiques interactifs</li>
            <li><i class="fas fa-check"></i> Analyse historique</li>
            <li><i class="fas fa-check"></i> Partage d'analyses</li>
            <li><i class="fas fa-check"></i> API pour vos apps</li>
        </ul>
    </div>
    
    <div class="feature-card">
        <div class="feature-header">
            <i class="fas fa-database"></i>
            <h3>Base de données pro</h3>
        </div>
        <ul class="feature-list">
            <li><i class="fas fa-check"></i> 50+ tournois suivis</li>
            <li><i class="fas fa-check"></i> 5000+ joueurs référencés</li>
            <li><i class="fas fa-check"></i> Historique 5 ans</li>
            <li><i class="fas fa-check"></i> Mise à jour temps réel</li>
            <li><i class="fas fa-check"></i> Données exclusives</li>
        </ul>
    </div>
</div>

<div style="text-align: center; margin: 60px 0;">
    <h3 style="font-size: 24px; margin-bottom: 20px;">API Access pour développeurs</h3>
    <pre style="background: rgba(0,0,0,0.5); padding: 20px; border-radius: 10px; max-width: 600px; margin: 0 auto; text-align: left;"><code>{
  "endpoint": "/api/ai/live-stats/{matchId}",
  "method": "GET",
  "response": {
    "match_id": "LIVE-2024-001",
    "win_probability": {...},
    "live_stats": {...}
  }
}</code></pre>
</div>
{% endblock %}