{% extends 'base.html.twig' %}

{% block title %}Analyse Équipe - {{ teamName }}{% endblock %}

{% block stylesheets %}
<style>
    .team-header {
        background: linear-gradient(135deg, rgba(255,45,45,0.2), rgba(0,0,0,0));
        border-radius: var(--radius-lg);
        padding: 40px;
        margin-bottom: 30px;
        position: relative;
        overflow: hidden;
    }

    .team-name {
        font-size: 48px;
        font-weight: 800;
        margin-bottom: 10px;
        background: linear-gradient(135deg, #fff, var(--red));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .team-meta {
        display: flex;
        gap: 20px;
        color: var(--text-muted);
        font-size: 16px;
        flex-wrap: wrap;
    }

    .team-meta i {
        color: var(--red);
        margin-right: 5px;
    }

    .team-stats-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 20px;
        margin: 30px 0;
    }

    .team-stat-card {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 20px;
        text-align: center;
        backdrop-filter: blur(10px);
        transition: var(--transition);
    }

    .team-stat-card:hover {
        transform: translateY(-5px);
        border-color: var(--red);
    }

    .team-stat-value {
        font-size: 32px;
        font-weight: 800;
        color: var(--red);
        margin-bottom: 5px;
    }

    .team-stat-label {
        color: var(--text-muted);
        font-size: 13px;
        text-transform: uppercase;
    }

    .analysis-content {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        padding: 40px;
        margin: 30px 0;
        line-height: 1.8;
        white-space: pre-wrap;
    }

    .players-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 20px;
        margin: 30px 0;
    }

    .player-card {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 20px;
        text-align: center;
        transition: var(--transition);
        cursor: pointer;
    }

    .player-card:hover {
        transform: translateY(-5px);
        border-color: var(--red);
        background: rgba(255,45,45,0.05);
    }

    .player-avatar {
        width: 80px;
        height: 80px;
        background: var(--red-gradient);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 15px;
        font-size: 32px;
        font-weight: 700;
        color: white;
    }

    .player-name-small {
        font-weight: 700;
        margin-bottom: 5px;
    }

    .player-role {
        font-size: 13px;
        color: var(--text-muted);
        margin-bottom: 10px;
    }

    .player-rating {
        display: inline-block;
        padding: 5px 15px;
        background: var(--red-soft);
        border-radius: 20px;
        color: var(--red);
        font-weight: 700;
        font-size: 14px;
    }

    .strategy-section {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        padding: 30px;
        margin: 30px 0;
    }

    .strategy-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 30px;
        margin-top: 20px;
    }

    .strategy-item {
        background: rgba(0,0,0,0.3);
        border-radius: var(--radius);
        padding: 20px;
    }

    .strategy-item h4 {
        color: var(--red);
        margin-bottom: 15px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .back-link {
        display: inline-block;
        margin-bottom: 20px;
        color: var(--text-muted);
        text-decoration: none;
        transition: var(--transition);
    }

    .back-link:hover {
        color: var(--red);
        transform: translateX(-5px);
    }

    @media (max-width: 992px) {
        .team-stats-grid {
            grid-template-columns: repeat(2, 1fr);
        }
        
        .strategy-grid {
            grid-template-columns: 1fr;
        }
    }

    @media (max-width: 768px) {
        .team-name {
            font-size: 32px;
        }
        
        .team-meta {
            flex-direction: column;
            gap: 10px;
        }
        
        .team-stats-grid {
            grid-template-columns: 1fr;
        }
    }
</style>
{% endblock %}

{% block body %}
<a href="{{ path('app_analyst_dashboard') }}" class="back-link">
    <i class="fas fa-arrow-left"></i> Retour au tableau de bord
</a>

<div class="team-header">
    <h1 class="team-name">{{ teamName }}</h1>
    <div class="team-meta">
        <span><i class="fas fa-gamepad"></i> {{ game|replace({'_': ' '})|title }}</span>
        <span><i class="fas fa-calendar"></i> Analyse du {{ timestamp }}</span>
        <span><i class="fas fa-microchip"></i> Généré par IA</span>
    </div>
</div>

<div class="team-stats-grid">
    <div class="team-stat-card">
        <div class="team-stat-value">{{ stats.overall_win_rate }}</div>
        <div class="team-stat-label">Win Rate Global</div>
    </div>
    <div class="team-stat-card">
        <div class="team-stat-value">{{ stats.first_blood_rate }}</div>
        <div class="team-stat-label">First Blood</div>
    </div>
    <div class="team-stat-card">
        <div class="team-stat-value">{{ stats.dragon_control }}</div>
        <div class="team-stat-label">Dragon Control</div>
    </div>
    <div class="team-stat-card">
        <div class="team-stat-value">{{ stats.team_synergy }}</div>
        <div class="team-stat-label">Synergie</div>
    </div>
</div>

<div class="analysis-content">
    {{ analysis|nl2br }}
</div>

<h2 style="margin: 40px 0 20px;">👥 Composition de l'équipe</h2>
<div class="players-grid">
    {% for player in players %}
    <div class="player-card" onclick="window.location.href='{{ path('app_analyst_player', {'playerName': player.name, 'game': game}) }}'">
        <div class="player-avatar">{{ player.name|first }}</div>
        <div class="player-name-small">{{ player.name }}</div>
        <div class="player-role">{{ player.role }}</div>
        <div class="player-rating">{{ player.rating }}</div>
    </div>
    {% endfor %}
</div>

<div class="strategy-section">
    <h3>🎯 Analyse stratégique</h3>
    <div class="strategy-grid">
        <div class="strategy-item">
            <h4><i class="fas fa-sword"></i> Forces</h4>
            <ul style="list-style: none; padding: 0;">
                <li style="margin-bottom: 10px;">✓ Early game agressif</li>
                <li style="margin-bottom: 10px;">✓ Objective control</li>
                <li style="margin-bottom: 10px;">✓ Team fights</li>
            </ul>
        </div>
        <div class="strategy-item">
            <h4><i class="fas fa-shield"></i> Faiblesses</h4>
            <ul style="list-style: none; padding: 0;">
                <li style="margin-bottom: 10px;">✗ Late game</li>
                <li style="margin-bottom: 10px;">✗ Split push defense</li>
                <li style="margin-bottom: 10px;">✗ Draft inflexible</li>
            </ul>
        </div>
    </div>
</div>

<div style="display: flex; gap: 15px; justify-content: center; margin: 40px 0;">
    <button onclick="window.print()" class="btn btn-secondary">
        <i class="fas fa-print"></i> Imprimer l'analyse
    </button>
    <a href="{{ path('app_analyst_export', {'type': 'team', 'name': teamName}) }}" class="btn btn-primary">
        <i class="fas fa-file-pdf"></i> Exporter en PDF
    </a>
</div>
{% endblock %}