{% extends 'base.html.twig' %}

{% block title %}Générateur IA - Plans d'entraînement professionnels{% endblock %}

{% block stylesheets %}
<style>
    /* Styles supplémentaires pour le formulaire */
    .ai-hero {
        text-align: center;
        padding: 40px 20px;
        margin-bottom: 40px;
        background: linear-gradient(135deg, rgba(255,45,45,0.1) 0%, rgba(0,0,0,0) 100%);
        border-radius: var(--radius-lg);
        position: relative;
        overflow: hidden;
    }

    .ai-hero::before {
        content: '';
        position: absolute;
        top: -50%;
        right: -50%;
        width: 200%;
        height: 200%;
        background: radial-gradient(circle, rgba(255,45,45,0.1) 0%, transparent 70%);
        animation: rotate 20s linear infinite;
    }

    @keyframes rotate {
        from { transform: rotate(0deg); }
        to { transform: rotate(360deg); }
    }

    .ai-hero h1 {
        font-size: 48px;
        font-weight: 800;
        margin-bottom: 20px;
        background: linear-gradient(135deg, #fff, var(--red));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        position: relative;
        z-index: 1;
    }

    .ai-hero p {
        font-size: 18px;
        color: var(--text-muted);
        max-width: 600px;
        margin: 0 auto;
        position: relative;
        z-index: 1;
    }

    .form-card {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        padding: 40px;
        backdrop-filter: blur(10px);
        box-shadow: var(--shadow-lg);
        animation: fadeInUp 0.8s ease-out;
        position: relative;
        overflow: hidden;
    }

    .form-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 4px;
        background: var(--red-gradient);
        animation: borderFlow 3s linear infinite;
    }

    .form-header {
        display: flex;
        align-items: center;
        gap: 20px;
        margin-bottom: 30px;
        padding-bottom: 20px;
        border-bottom: 1px solid var(--border-light);
    }

    .form-header-icon {
        width: 60px;
        height: 60px;
        background: var(--red-gradient);
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 24px;
        color: white;
        animation: pulse 2s infinite;
    }

    .form-header-title h2 {
        font-size: 24px;
        font-weight: 700;
        margin-bottom: 5px;
    }

    .form-header-title p {
        color: var(--text-muted);
        font-size: 14px;
    }

    .form-group {
        margin-bottom: 25px;
        animation: fadeInUp 0.5s ease-out backwards;
    }

    .form-group:nth-child(1) { animation-delay: 0.1s; }
    .form-group:nth-child(2) { animation-delay: 0.2s; }
    .form-group:nth-child(3) { animation-delay: 0.3s; }
    .form-group:nth-child(4) { animation-delay: 0.4s; }
    .form-group:nth-child(5) { animation-delay: 0.5s; }
    .form-group:nth-child(6) { animation-delay: 0.6s; }

    .form-label {
        display: block;
        font-size: 14px;
        font-weight: 600;
        margin-bottom: 8px;
        color: var(--text-light);
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .form-label i {
        color: var(--red);
        margin-right: 8px;
        width: 16px;
    }

    .form-control, .form-select {
        width: 100%;
        padding: 14px 18px;
        background: rgba(0,0,0,0.3);
        border: 1px solid var(--border-light);
        border-radius: 10px;
        color: var(--text-light);
        font-size: 15px;
        transition: var(--transition);
        cursor: pointer;
    }

    .form-control:hover, .form-select:hover {
        border-color: var(--red);
        background: rgba(255,45,45,0.05);
    }

    .form-control:focus, .form-select:focus {
        outline: none;
        border-color: var(--red);
        box-shadow: 0 0 0 3px rgba(255,45,45,0.2);
        background: rgba(255,45,45,0.1);
    }

    .form-control option, .form-select option {
        background: var(--bg-main);
        color: var(--text-light);
    }

    .form-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
    }

    .textarea-control {
        min-height: 120px;
        resize: vertical;
        font-family: 'Inter', sans-serif;
    }

    .features-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 20px;
        margin: 30px 0;
        padding: 20px;
        background: rgba(255,45,45,0.05);
        border-radius: var(--radius);
        animation: fadeInUp 0.7s ease-out;
    }

    .feature-item {
        text-align: center;
    }

    .feature-icon {
        width: 40px;
        height: 40px;
        background: var(--red-soft);
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 10px;
        color: var(--red);
        font-size: 18px;
    }

    .feature-text {
        font-size: 12px;
        font-weight: 600;
        color: var(--text-muted);
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .feature-value {
        font-size: 14px;
        font-weight: 700;
        color: var(--text-light);
    }

    .btn-submit {
        width: 100%;
        padding: 18px;
        background: var(--red-gradient);
        border: none;
        border-radius: 10px;
        color: white;
        font-size: 16px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
        cursor: pointer;
        transition: var(--transition);
        position: relative;
        overflow: hidden;
        margin-top: 20px;
        animation: fadeInUp 0.8s ease-out;
    }

    .btn-submit::before {
        content: '';
        position: absolute;
        top: 50%;
        left: 50%;
        width: 0;
        height: 0;
        border-radius: 50%;
        background: rgba(255,255,255,0.2);
        transform: translate(-50%, -50%);
        transition: width 0.6s, height 0.6s;
    }

    .btn-submit:hover::before {
        width: 300px;
        height: 300px;
    }

    .btn-submit:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 30px rgba(255,45,45,0.3);
    }

    .btn-submit i {
        margin-right: 10px;
        animation: spin 2s linear infinite;
    }

    @keyframes spin {
        from { transform: rotate(0deg); }
        to { transform: rotate(360deg); }
    }

    .info-badge {
        background: rgba(255,45,45,0.1);
        border: 1px solid rgba(255,45,45,0.3);
        border-radius: 8px;
        padding: 15px 20px;
        margin-top: 20px;
        display: flex;
        align-items: center;
        gap: 15px;
        animation: fadeInUp 0.9s ease-out;
    }

    .info-badge i {
        font-size: 24px;
        color: var(--red);
    }

    .info-badge-content {
        flex: 1;
    }

    .info-badge-title {
        font-weight: 700;
        margin-bottom: 5px;
    }

    .info-badge-text {
        font-size: 13px;
        color: var(--text-muted);
    }

    .stats-mini {
        display: flex;
        justify-content: space-around;
        margin-top: 30px;
        padding-top: 20px;
        border-top: 1px solid var(--border-light);
    }

    .stat-mini-item {
        text-align: center;
    }

    .stat-mini-value {
        font-size: 24px;
        font-weight: 800;
        color: var(--red);
    }

    .stat-mini-label {
        font-size: 12px;
        color: var(--text-muted);
        text-transform: uppercase;
    }

    @media (max-width: 768px) {
        .form-card {
            padding: 25px;
        }

        .form-row {
            grid-template-columns: 1fr;
        }

        .features-grid {
            grid-template-columns: 1fr;
        }

        .ai-hero h1 {
            font-size: 32px;
        }
    }
</style>
{% endblock %}

{% block body %}
<div class="ai-hero">
    <h1>🏋️ Générateur de plans d'entraînement IA</h1>
    <p>Créez des programmes d'entraînement personnalisés et professionnels en quelques secondes grâce à l'intelligence artificielle</p>
</div>

<div class="row">
    <div class="col-lg-8 mx-auto">
        <div class="form-card">
            <div class="form-header">
                <div class="form-header-icon">
                    <i class="fas fa-robot"></i>
                </div>
                <div class="form-header-title">
                    <h2>Configurez votre séance</h2>
                    <p>Remplissez les informations ci-dessous pour générer un plan sur mesure</p>
                </div>
            </div>

            <form action="{{ path('app_ai_workout_generate') }}" method="POST" id="workoutForm">
                <div class="form-group">
                    <label class="form-label">
                        <i class="fas fa-futbol"></i>
                        Sport *
                    </label>
                    <select name="sport" class="form-select" required id="sportSelect">
                        <option value="" disabled selected>Choisissez votre sport</option>
                        <option value="football">⚽ Football</option>
                        <option value="basketball">🏀 Basketball</option>
                        <option value="tennis">🎾 Tennis</option>
                        <option value="rugby">🏉 Rugby</option>
                        <option value="running">🏃 Running</option>
                        <option value="natation">🏊 Natation</option>
                        <option value="musculation">💪 Musculation</option>
                        <option value="crossfit">🔥 CrossFit</option>
                        <option value="boxe">🥊 Boxe</option>
                        <option value="cyclisme">🚴 Cyclisme</option>
                    </select>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">
                            <i class="fas fa-chart-line"></i>
                            Niveau *
                        </label>
                        <select name="niveau" class="form-select" required>
                            <option value="debutant">🌱 Débutant</option>
                            <option value="intermediaire" selected>📊 Intermédiaire</option>
                            <option value="avance">⚡ Avancé</option>
                            <option value="expert">🏆 Expert</option>
                            <option value="professionnel">🌟 Professionnel</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label class="form-label">
                            <i class="fas fa-clock"></i>
                            Durée (minutes) *
                        </label>
                        <select name="duree" class="form-select" required>
                            <option value="30">30 minutes</option>
                            <option value="45">45 minutes</option>
                            <option value="60" selected>60 minutes</option>
                            <option value="75">75 minutes</option>
                            <option value="90">90 minutes</option>
                            <option value="120">2 heures</option>
                        </select>
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">
                            <i class="fas fa-bullseye"></i>
                            Objectif principal *
                        </label>
                        <select name="objectif" class="form-select" required>
                            <option value="endurance">💨 Endurance</option>
                            <option value="force">💪 Force</option>
                            <option value="technique">🎯 Technique</option>
                            <option value="vitesse">⚡ Vitesse</option>
                            <option value="perte_poids">⚖️ Perte de poids</option>
                            <option value="musculation">🏋️ Prise de masse</option>
                            <option value="general" selected>📋 Général</option>
                            <option value="recuperation">🧘 Récupération</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label class="form-label">
                            <i class="fas fa-calendar-alt"></i>
                            Âge
                        </label>
                        <input type="number" name="age" class="form-control" value="25" min="15" max="80" step="1">
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label">
                        <i class="fas fa-pencil-alt"></i>
                        Préférences spécifiques (optionnel)
                    </label>
                    <textarea name="positions" class="form-control textarea-control" placeholder="Ex: Attaquant, gaucher, travaille le cardio&#10;Ou: Problème de genou, préfère les exercices en extérieur&#10;Ou: Prépare une compétition dans 2 mois...">Attaquant, explosif, bon jeu de tête</textarea>
                    <small style="color: var(--text-muted); display: block; margin-top: 5px;">
                        <i class="fas fa-info-circle"></i> Plus vous donnez de détails, plus le plan sera personnalisé
                    </small>
                </div>

                <div class="features-grid">
                    <div class="feature-item">
                        <div class="feature-icon">
                            <i class="fas fa-microchip"></i>
                        </div>
                        <div class="feature-text">IA</div>
                        <div class="feature-value">OpenAI GPT-4</div>
                    </div>
                    <div class="feature-item">
                        <div class="feature-icon">
                            <i class="fas fa-bolt"></i>
                        </div>
                        <div class="feature-text">Génération</div>
                        <div class="feature-value">5-10 secondes</div>
                    </div>
                    <div class="feature-item">
                        <div class="feature-icon">
                            <i class="fas fa-medal"></i>
                        </div>
                        <div class="feature-text">Expertise</div>
                        <div class="feature-value">Coach pro</div>
                    </div>
                </div>

                <button type="submit" class="btn-submit" id="submitBtn">
                    <i class="fas fa-magic"></i>
                    GÉNÉRER MON PLAN D'ENTRAÎNEMENT
                </button>

                <div class="info-badge">
                    <i class="fas fa-shield-alt"></i>
                    <div class="info-badge-content">
                        <div class="info-badge-title">✅ IA entraînée par des coachs professionnels</div>
                        <div class="info-badge-text">Votre plan est généré en temps réel par OpenAI avec des prompts spécialisés pour chaque sport</div>
                    </div>
                </div>
            </form>

            <div class="stats-mini">
                <div class="stat-mini-item">
                    <div class="stat-mini-value">+500</div>
                    <div class="stat-mini-label">Plans générés</div>
                </div>
                <div class="stat-mini-item">
                    <div class="stat-mini-value">98%</div>
                    <div class="stat-mini-label">Satisfaction</div>
                </div>
                <div class="stat-mini-item">
                    <div class="stat-mini-value">15</div>
                    <div class="stat-mini-label">Sports</div>
                </div>
            </div>
        </div>

        <div style="text-align: center; margin-top: 30px;">
            <a href="{{ path('app_ai_workout_form') }}" style="color: var(--text-muted); text-decoration: none; font-size: 13px;">
                <i class="fas fa-sync-alt"></i> Réinitialiser le formulaire
            </a>
        </div>
    </div>
</div>

<script>
document.getElementById('workoutForm').addEventListener('submit', function(e) {
    const btn = document.getElementById('submitBtn');
    btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> GÉNÉRATION EN COURS...';
    btn.style.opacity = '0.8';
    btn.disabled = true;
});
</script>
{% endblock %}