{% extends 'base.html.twig' %}

{% block title %}Hello AiController!{% endblock %}

{% block body %}
<style>
    .example-wrapper { margin: 1em auto; max-width: 800px; width: 95%; font: 18px/1.5 sans-serif; }
    .example-wrapper code { background: #F5F5F5; padding: 2px 6px; }
    .ai-dashboard {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 20px;
        margin-top: 30px;
    }
    .ai-card {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 25px;
        transition: var(--transition);
        text-decoration: none;
        color: var(--text-main);
    }
    .ai-card:hover {
        transform: translateY(-5px);
        border-color: var(--red);
        box-shadow: var(--shadow);
    }
    .ai-card i {
        font-size: 40px;
        color: var(--red);
        margin-bottom: 15px;
    }
    .ai-card h3 {
        margin-bottom: 10px;
    }
    .ai-card p {
        color: var(--text-muted);
        font-size: 14px;
    }
</style>

<div class="example-wrapper">
    <h1>Hello {{ controller_name }}! ✅</h1>

    <p>Bienvenue sur l'espace Intelligence Artificielle de Phantom Force</p>
    
    <div class="ai-dashboard">
        <a href="{{ path('app_ai_workout_form') }}" class="ai-card">
            <i class="fas fa-dumbbell"></i>
            <h3>🏋️ Coach sportif IA</h3>
            <p>Générez des plans d'entraînement personnalisés pour tous les sports</p>
        </a>
        
        <a href="{{ path('app_analyst_dashboard') }}" class="ai-card">
            <i class="fas fa-chart-line"></i>
            <h3>📊 Analyste Esport Pro</h3>
            <p>Analysez les joueurs, équipes et matchs avec l'IA</p>
        </a>
        
        <a href="{{ path('app_ai') }}" class="ai-card">
            <i class="fas fa-robot"></i>
            <h3>🤖 API Test</h3>
            <p>Testez la route /ai/generate (JSON)</p>
        </a>
    </div>

    <div class="mt-4">
        <h3>Routes disponibles :</h3>
        <ul>
            <li><a href="{{ path('app_ai_workout_form') }}">/ai/workout-form</a> - Générateur de plans d'entraînement</li>
            <li><a href="{{ path('app_analyst_dashboard') }}">/ai/analyst</a> - Dashboard Analyste Esport</li>
            <li><a href="{{ path('app_analyst_player_search') }}?playerName=Faker">/ai/analyst/player/Faker</a> - Analyser un joueur</li>
            <li><a href="{{ path('app_analyst_team_search') }}?teamName=T1">/ai/analyst/team/T1</a> - Analyser une équipe</li>
            <li><a href="{{ path('app_analyst_live') }}">/ai/analyst/live</a> - Matchs en direct</li>
            <li><a href="{{ path('app_ai_generate') }}">/ai/generate</a> - API JSON de test</li>
        </ul>
    </div>

    <div class="mt-4">
        <p>This friendly message is coming from:</p>
        <ul>
            <li>Your controller at <code>C:/Users/arbi/Downloads/esport (3)/esport/src/Controller/AiController.php</code></li>
            <li>Your template at <code>C:/Users/arbi/Downloads/esport (3)/esport/templates/ai/index.html.twig</code></li>
        </ul>
    </div>
</div>
{% endblock %}