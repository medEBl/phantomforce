{% extends 'base.html.twig' %}

{% block title %}Analyse Joueur - {{ playerName }}{% endblock %}

{% block stylesheets %}
<style>
    .player-header {
        background: linear-gradient(135deg, rgba(255,45,45,0.2), rgba(0,0,0,0));
        border-radius: var(--radius-lg);
        padding: 40px;
        margin-bottom: 30px;
        position: relative;
        overflow: hidden;
    }

    .player-name {
        font-size: 48px;
        font-weight: 800;
        margin-bottom: 10px;
        background: linear-gradient(135deg, #fff, var(--red));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .player-meta {
        display: flex;
        gap: 20px;
        color: var(--text-muted);
        font-size: 16px;
        flex-wrap: wrap;
    }

    .player-meta i {
        color: var(--red);
        margin-right: 5px;
    }

    .stats-overview {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 20px;
        margin: 30px 0;
    }

    .stat-box {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 25px;
        text-align: center;
        backdrop-filter: blur(10px);
        transition: var(--transition);
    }

    .stat-box:hover {
        transform: translateY(-5px);
        border-color: var(--red);
    }

    .stat-box .value {
        font-size: 42px;
        font-weight: 800;
        color: var(--red);
        margin-bottom: 5px;
    }

    .stat-box .label {
        color: var(--text-muted);
        font-size: 14px;
        text-transform: uppercase;
    }

    .analysis-content {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        padding: 40px;
        margin: 30px 0;
        line-height: 1.8;
        white-space: pre-wrap;
        font-family: 'Inter', sans-serif;
    }

    .stats-detailed {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 20px;
        margin: 30px 0;
    }

    .stat-item {
        display: flex;
        justify-content: space-between;
        padding: 15px;
        background: rgba(0,0,0,0.3);
        border-radius: 8px;
        border: 1px solid var(--border-light);
        transition: var(--transition);
    }

    .stat-item:hover {
        border-color: var(--red);
        background: rgba(255,45,45,0.05);
    }

    .stat-item .stat-name {
        color: var(--text-muted);
    }

    .stat-item .stat-value {
        font-weight: 700;
        color: var(--red);
    }

    .progress-bar-custom {
        width: 100%;
        height: 8px;
        background: rgba(255,255,255,0.1);
        border-radius: 4px;
        margin-top: 5px;
        overflow: hidden;
    }

    .progress-fill {
        height: 100%;
        background: var(--red-gradient);
        border-radius: 4px;
        transition: width 1s ease-out;
    }

    .strengths-weaknesses {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
        margin: 30px 0;
    }

    .strengths-box, .weaknesses-box {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 25px;
    }

    .strengths-box h3, .weaknesses-box h3 {
        margin-bottom: 20px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .strengths-box h3 i {
        color: var(--green);
    }

    .weaknesses-box h3 i {
        color: var(--red);
    }

    .strength-item, .weakness-item {
        padding: 12px;
        border-bottom: 1px solid var(--border-light);
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .strength-item i {
        color: var(--green);
    }

    .weakness-item i {
        color: var(--red);
    }

    .back-link {
        display: inline-block;
        margin-bottom: 20px;
        color: var(--text-muted);
        text-decoration: none;
        transition: var(--transition);
    }

    .back-link:hover {
        color: var(--red);
        transform: translateX(-5px);
    }

    @media (max-width: 768px) {
        .stats-overview,
        .stats-detailed,
        .strengths-weaknesses {
            grid-template-columns: 1fr;
        }
        
        .player-name {
            font-size: 32px;
        }
        
        .player-meta {
            flex-direction: column;
            gap: 10px;
        }
    }
</style>
{% endblock %}

{% block body %}
<a href="{{ path('app_analyst_dashboard') }}" class="back-link">
    <i class="fas fa-arrow-left"></i> Retour au tableau de bord
</a>

<div class="player-header">
    <h1 class="player-name">{{ playerName }}</h1>
    <div class="player-meta">
        <span><i class="fas fa-gamepad"></i> {{ game|replace({'_': ' '})|title }}</span>
        <span><i class="fas fa-tag"></i> {{ role|default('Joueur')|title }}</span>
        <span><i class="fas fa-calendar"></i> Analyse du {{ timestamp }}</span>
        <span><i class="fas fa-microchip"></i> Généré par IA</span>
    </div>
</div>

<div class="stats-overview">
    <div class="stat-box">
        <div class="value">{{ stats.kda }}</div>
        <div class="label">KDA Ratio</div>
    </div>
    <div class="stat-box">
        <div class="value">{{ stats.win_rate }}</div>
        <div class="label">Win Rate</div>
    </div>
    <div class="stat-box">
        <div class="value">{{ stats.games_played }}</div>
        <div class="label">Games joués</div>
    </div>
</div>

<div class="analysis-content">
    {{ analysis|nl2br }}
</div>

<div class="strengths-weaknesses">
    <div class="strengths-box">
        <h3><i class="fas fa-plus-circle"></i> Points forts</h3>
        <div class="strength-item">
            <i class="fas fa-check"></i> Mécaniques exceptionnelles
        </div>
        <div class="strength-item">
            <i class="fas fa-check"></i> Vision de jeu
        </div>
        <div class="strength-item">
            <i class="fas fa-check"></i> Prise de décision
        </div>
    </div>
    <div class="weaknesses-box">
        <h3><i class="fas fa-minus-circle"></i> Points à améliorer</h3>
        <div class="weakness-item">
            <i class="fas fa-exclamation"></i> Consistency
        </div>
        <div class="weakness-item">
            <i class="fas fa-exclamation"></i> Communication
        </div>
        <div class="weakness-item">
            <i class="fas fa-exclamation"></i> Tilt management
        </div>
    </div>
</div>

<div class="stats-detailed">
    <div class="stat-item">
        <span class="stat-name"><i class="fas fa-skull"></i> Kill Participation</span>
        <span class="stat-value">{{ stats.kill_participation }}</span>
    </div>
    <div class="stat-item">
        <span class="stat-name"><i class="fas fa-coins"></i> CS par minute</span>
        <span class="stat-value">{{ stats.cs_per_min }}</span>
    </div>
    <div class="stat-item">
        <span class="stat-name"><i class="fas fa-bolt"></i> Dégâts par minute</span>
        <span class="stat-value">{{ stats.damage_per_min }}</span>
    </div>
    <div class="stat-item">
        <span class="stat-name"><i class="fas fa-eye"></i> Vision score</span>
        <span class="stat-value">{{ stats.vision_score }}</span>
    </div>
    <div class="stat-item">
        <span class="stat-name"><i class="fas fa-trophy"></i> MVP Count</span>
        <span class="stat-value">{{ stats.mvp_count }}</span>
    </div>
    <div class="stat-item">
        <span class="stat-name"><i class="fas fa-chart-line"></i> Performance Trend</span>
        <span class="stat-value">{{ stats.form.performance_trend }}</span>
    </div>
</div>

<div style="margin: 40px 0;">
    <h3>📈 Forme récente</h3>
    <div style="background: var(--bg-card); border-radius: var(--radius); padding: 20px; margin-top: 15px;">
        <div style="display: flex; justify-content: space-between; margin-bottom: 15px;">
            <span>Performance globale</span>
            <span>{{ stats.form.performance_trend }}</span>
        </div>
        <div class="progress-bar-custom">
            <div class="progress-fill" style="width: {{ stats.form.performance_trend|replace({'%': ''}) }}%;"></div>
        </div>
        <div style="display: flex; gap: 30px; margin-top: 20px; flex-wrap: wrap;">
            <div><i class="fas fa-history"></i> Derniers matchs: {{ stats.form.last_5 }}</div>
            <div><i class="fas fa-fire"></i> Série actuelle: {{ stats.form.current_streak }}</div>
        </div>
    </div>
</div>

<div style="display: flex; gap: 15px; justify-content: center; margin: 40px 0;">
    <button onclick="window.print()" class="btn btn-secondary">
        <i class="fas fa-print"></i> Imprimer l'analyse
    </button>
    <a href="{{ path('app_analyst_export', {'type': 'player', 'name': playerName}) }}" class="btn btn-primary">
        <i class="fas fa-file-pdf"></i> Exporter en PDF
    </a>
</div>
{% endblock %}