{% extends 'base.html.twig' %}

{% block title %}Recommandations - {{ gameName }}{% endblock %}

{% block body %}
<div class="container">
    <h1>🎮 Jeux similaires à "{{ gameName }}"</h1>
    
    <div class="recommendations-grid">
        {% for rec in recommendations %}
            <div class="rec-card">
                <h3>{{ rec.name }}</h3>
                <p>{{ rec.reason }}</p>
                <a href="#" class="btn-view">Voir le jeu</a>
            </div>
        {% else %}
            <p>Aucune recommandation trouvée.</p>
        {% endfor %}
    </div>
</div>

<style>
.recommendations-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 20px;
    margin-top: 30px;
}

.rec-card {
    background: var(--bg-card);
    border: 2px solid var(--neon-green);
    border-radius: 10px;
    padding: 20px;
    transition: var(--transition);
}

.rec-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 5px 20px rgba(0, 255, 65, 0.3);
}

.rec-card h3 {
    color: var(--neon-green);
    margin-bottom: 10px;
}

.btn-view {
    display: inline-block;
    margin-top: 15px;
    padding: 8px 15px;
    background: var(--neon-green);
    color: black;
    text-decoration: none;
    border-radius: 5px;
    font-weight: 600;
}
</style>
{% endblock %}