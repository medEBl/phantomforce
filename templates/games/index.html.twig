{% extends 'base.html.twig' %}

{% block title %}🎮 Jeux Gratuits - FreeToGame{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
    :root {
        --blood-red: #ff0000;
        --fire-red: #ff3300;
        --dark-red: #cc0000;
        --neon-red: #ff003c;
        --red-glow: rgba(255, 0, 0, 0.7);
        --red-light: rgba(255, 51, 51, 0.3);
        --black-bg: #000000;
        --dark-gray: #1a1a1a;
        --gray: #333333;
        --light-gray: #666666;
        --white: #ffffff;
    }
    
    .games-header {
        background: linear-gradient(135deg, #000000 0%, #330000 50%, #660000 100%);
        padding: 60px 20px;
        text-align: center;
        border-radius: 15px;
        margin-bottom: 30px;
        position: relative;
        overflow: hidden;
        border: 2px solid var(--blood-red);
        box-shadow: 0 0 30px var(--red-glow);
    }
    
    .games-header::before {
        content: '🎮';
        position: absolute;
        top: -20px;
        left: -20px;
        font-size: 150px;
        opacity: 0.2;
        transform: rotate(-15deg);
        color: var(--blood-red);
    }
    
    .games-header::after {
        content: '';
        position: absolute;
        top: -50%;
        left: -50%;
        width: 200%;
        height: 200%;
        background: radial-gradient(circle, rgba(255,0,0,0.1) 0%, transparent 70%);
        animation: rotate 20s linear infinite;
    }
    
    @keyframes rotate {
        from { transform: rotate(0deg); }
        to { transform: rotate(360deg); }
    }
    
    .games-header h1 {
        font-family: 'Orbitron', sans-serif;
        font-size: 3.5rem;
        font-weight: 900;
        color: white;
        margin-bottom: 10px;
        text-shadow: 0 0 20px var(--blood-red);
        position: relative;
        z-index: 1;
        animation: textPulse 2s infinite alternate;
    }
    
    @keyframes textPulse {
        from { text-shadow: 0 0 20px rgba(255, 0, 0, 0.5); }
        to { text-shadow: 0 0 30px rgba(255, 0, 0, 0.9), 0 0 40px rgba(255, 0, 0, 0.5); }
    }
    
    .games-header p {
        color: var(--fire-red);
        font-size: 1.2rem;
        font-family: 'Rajdhani', sans-serif;
        letter-spacing: 2px;
        position: relative;
        z-index: 1;
    }
    
    .back-link {
        display: inline-block;
        margin-bottom: 20px;
        color: var(--fire-red);
        text-decoration: none;
        font-size: 1.1rem;
        font-family: 'Orbitron', sans-serif;
        transition: all 0.3s;
        position: relative;
        padding-left: 20px;
    }
    
    .back-link::before {
        content: '←';
        position: absolute;
        left: 0;
        top: 50%;
        transform: translateY(-50%);
        transition: left 0.3s;
    }
    
    .back-link:hover {
        color: var(--blood-red);
        padding-left: 25px;
        text-shadow: 0 0 10px var(--blood-red);
    }
    
    .filter-bar {
        background: var(--dark-gray);
        padding: 25px;
        border-radius: 10px;
        margin-bottom: 30px;
        display: flex;
        gap: 15px;
        flex-wrap: wrap;
        align-items: center;
        border: 1px solid var(--dark-red);
        box-shadow: 0 0 20px rgba(255, 0, 0, 0.1);
        position: relative;
        overflow: hidden;
    }
    
    .filter-bar::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 2px;
        background: linear-gradient(90deg, var(--blood-red), var(--fire-red), var(--dark-red));
        animation: slide 3s linear infinite;
    }
    
    @keyframes slide {
        0% { background-position: 0% 0; }
        100% { background-position: 200% 0; }
    }
    
    .filter-select {
        padding: 12px 20px;
        background: #000000;
        border: 1px solid var(--dark-red);
        border-radius: 5px;
        color: white;
        font-size: 1rem;
        min-width: 180px;
        font-family: 'Rajdhani', sans-serif;
        cursor: pointer;
        transition: all 0.3s;
    }
    
    .filter-select:hover, .filter-select:focus {
        border-color: var(--blood-red);
        box-shadow: 0 0 15px var(--red-glow);
        outline: none;
    }
    
    .filter-select option {
        background: #000000;
        color: white;
    }
    
    .filter-btn {
        padding: 12px 30px;
        background: linear-gradient(45deg, var(--dark-red), var(--blood-red));
        border: none;
        border-radius: 5px;
        color: white;
        font-weight: bold;
        font-family: 'Orbitron', sans-serif;
        text-transform: uppercase;
        letter-spacing: 1px;
        cursor: pointer;
        transition: all 0.3s;
        position: relative;
        overflow: hidden;
    }
    
    .filter-btn::before {
        content: '';
        position: absolute;
        top: 0;
        left: -100%;
        width: 100%;
        height: 100%;
        background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.3), transparent);
        transition: left 0.5s;
    }
    
    .filter-btn:hover::before {
        left: 100%;
    }
    
    .filter-btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 5px 20px var(--red-glow);
    }
    
    .games-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 25px;
        margin-top: 30px;
    }
    
    .game-card {
        background: linear-gradient(135deg, #1a0000, #000000);
        border-radius: 10px;
        overflow: hidden;
        transition: all 0.3s;
        border: 1px solid var(--dark-red);
        cursor: pointer;
        position: relative;
    }
    
    .game-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 3px;
        background: linear-gradient(90deg, var(--blood-red), var(--fire-red), var(--dark-red));
        transform: translateX(-100%);
        transition: transform 0.5s;
    }
    
    .game-card:hover::before {
        transform: translateX(0);
    }
    
    .game-card:hover {
        transform: translateY(-10px);
        box-shadow: 0 10px 30px var(--red-glow);
        border-color: var(--blood-red);
    }
    
    .game-image {
        width: 100%;
        height: 160px;
        object-fit: cover;
        transition: transform 0.5s;
    }
    
    .game-card:hover .game-image {
        transform: scale(1.05);
    }
    
    .game-info {
        padding: 20px;
        background: linear-gradient(180deg, transparent, rgba(0,0,0,0.8));
    }
    
    .game-title {
        color: white;
        font-size: 1.3rem;
        font-weight: bold;
        font-family: 'Orbitron', sans-serif;
        margin-bottom: 8px;
        text-shadow: 0 0 5px rgba(255,0,0,0.5);
    }
    
    .game-meta {
        display: flex;
        justify-content: space-between;
        color: var(--fire-red);
        font-size: 0.9rem;
        margin-bottom: 10px;
        font-family: 'Rajdhani', sans-serif;
        letter-spacing: 1px;
    }
    
    .game-platform {
        background: #330000;
        padding: 3px 10px;
        border-radius: 3px;
        color: var(--fire-red);
        font-size: 0.8rem;
        border: 1px solid var(--dark-red);
    }
    
    .game-description {
        color: #cc9999;
        font-size: 0.9rem;
        line-height: 1.5;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        font-family: 'Rajdhani', sans-serif;
    }
    
    .no-results {
        grid-column: 1/-1;
        text-align: center;
        padding: 60px 20px;
        background: linear-gradient(135deg, #1a0000, #000000);
        border: 2px dashed var(--dark-red);
        border-radius: 15px;
        color: #b3b3b3;
    }
    
    .no-results h3 {
        color: var(--fire-red);
        font-family: 'Orbitron', sans-serif;
        font-size: 2rem;
        margin-bottom: 15px;
        text-shadow: 0 0 10px rgba(255,0,0,0.5);
    }
    
    .no-results p {
        color: #cc9999;
        font-size: 1.1rem;
    }
    
    .pagination {
        display: flex;
        justify-content: center;
        gap: 10px;
        margin: 40px 0;
    }
    
    .pagination-btn {
        padding: 10px 15px;
        background: #1a0000;
        border: 1px solid var(--dark-red);
        border-radius: 5px;
        color: white;
        text-decoration: none;
        transition: all 0.3s;
    }
    
    .pagination-btn:hover {
        background: var(--dark-red);
        border-color: var(--blood-red);
        box-shadow: 0 0 15px var(--red-glow);
    }
    
    .pagination-btn.active {
        background: var(--blood-red);
        border-color: var(--blood-red);
    }
    
    @media (max-width: 768px) {
        .games-header h1 {
            font-size: 2.5rem;
        }
        
        .filter-bar {
            flex-direction: column;
            align-items: stretch;
        }
        
        .filter-select, .filter-btn {
            width: 100%;
        }
        
        .games-grid {
            grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
        }
    }
</style>
{% endblock %}

{% block body %}
<div class="container">
    <a href="{{ path('app_matchy_index') }}" class="back-link">Retour aux matchs</a>
    
    <div class="games-header">
        <h1>🎮 JEUX GRATUITS</h1>
        <p>DÉCOUVREZ LES MEILLEURS JEUX FREE-TO-PLAY</p>
    </div>
    
    <!-- Filtres -->
    <form method="GET" class="filter-bar">
        <select name="platform" class="filter-select">
            {% for key, label in platforms %}
                <option value="{{ key }}" {% if current_platform == key %}selected{% endif %}>{{ label }}</option>
            {% endfor %}
        </select>
        
        <select name="category" class="filter-select">
            {% for key, label in categories %}
                <option value="{{ key }}" {% if current_category == key %}selected{% endif %}>{{ label }}</option>
            {% endfor %}
        </select>
        
        <select name="sort" class="filter-select">
            <option value="release-date" {% if current_sort == 'release-date' %}selected{% endif %}>Date de sortie</option>
            <option value="popularity" {% if current_sort == 'popularity' %}selected{% endif %}>Popularité</option>
            <option value="alphabetical" {% if current_sort == 'alphabetical' %}selected{% endif %}>Alphabétique</option>
        </select>
        
        <button type="submit" class="filter-btn">Filtrer</button>
    </form>
    
    <!-- Grille des jeux -->
    <div class="games-grid">
        {% for game in games %}
            <div class="game-card" onclick="window.location.href='{{ path('app_games_show', {'id': game.id}) }}'">
                <img src="{{ game.thumbnail }}" alt="{{ game.title }}" class="game-image">
                <div class="game-info">
                    <div class="game-title">{{ game.title }}</div>
                    <div class="game-meta">
                        <span>{{ game.genre }}</span>
                        <span class="game-platform">{{ game.platform }}</span>
                    </div>
                    <div class="game-description">{{ game.short_description }}</div>
                </div>
            </div>
        {% else %}
            <div class="no-results">
                <h3>🔥 AUCUN JEU TROUVÉ</h3>
                <p>Essayez de modifier vos filtres pour découvrir plus de jeux</p>
            </div>
        {% endfor %}
    </div>
</div>
{% endblock %}