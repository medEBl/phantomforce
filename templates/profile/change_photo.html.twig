{% extends 'basefront.html.twig' %}

{% block title %}Change Photo - PhantomForce{% endblock %}

{% block body %}
<div class="cyber-container" style="max-width: 600px; margin: 40px auto;">
    <h1>UPDATE PROFILE PHOTO</h1>
    
    {% for flash in app.flashes('error') %}
        <div class="error-box">{{ flash }}</div>
    {% endfor %}
    
    <div style="text-align: center; margin-bottom: 30px;">
        <div class="avatar" style="width: 150px; height: 150px; margin: 0 auto; font-size: 50px;">
            {% if app.user.profilePhotoUrl %}
                <img src="{{ app.user.profilePhotoUrl }}" alt="{{ app.user.username }}" 
                     style="width: 100%; height: 100%; border-radius: 50%; object-fit: cover; border: 3px solid var(--red);">
            {% else %}
                {{ app.user.initials }}
            {% endif %}
        </div>
        <p style="color: var(--text-muted); margin-top: 10px;">Current Photo</p>
    </div>
    
    {{ form_start(form, {'attr': {'enctype': 'multipart/form-data', 'class': 'cyber-form'}}) }}
        <div class="form-group" style="grid-column: 1 / -1;">
            {{ form_label(form.photo, 'SELECT NEW PHOTO', {'label_attr': {'class': 'form-label'}}) }}
            {{ form_widget(form.photo, {'attr': {'class': 'form-input', 'accept': 'image/*'}}) }}
            {{ form_errors(form.photo) }}
            <div class="form-hint">Format: JPEG, PNG, GIF, WEBP (max 5MB)</div>
            
            <div id="photoPreview" style="margin-top: 20px; display: none; text-align: center;">
                <img id="previewImage" src="#" alt="Preview" 
                     style="width: 150px; height: 150px; border-radius: 50%; border: 3px solid var(--neon-red); object-fit: cover;">
            </div>
        </div>

        <div class="submit-section" style="grid-column: 1 / -1;">
            <button type="submit" class="enlist-button" style="padding: 15px 40px; font-size: 1.1em;">
                <span>UPLOAD PHOTO</span>
            </button>
        </div>
    {{ form_end(form) }}
    
    <div style="text-align: center; margin-top: 20px;">
        <a href="{{ path('app_profile') }}" class="cyber-link">← BACK TO PROFILE</a>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const photoInput = document.getElementById('{{ form.photo.vars.id }}');
    const previewContainer = document.getElementById('photoPreview');
    const previewImage = document.getElementById('previewImage');
    
    if (photoInput) {
        photoInput.addEventListener('change', function() {
            const file = this.files[0];
            if (file) {
                const reader = new FileReader();
                
                reader.onload = function(e) {
                    previewImage.src = e.target.result;
                    previewContainer.style.display = 'block';
                }
                
                reader.readAsDataURL(file);
            } else {
                previewContainer.style.display = 'none';
            }
        });
    }
});
</script>
{% endblock %}