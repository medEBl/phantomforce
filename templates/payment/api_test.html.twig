{% extends 'base.html.twig' %}

{% block title %}API Paiement - Test{% endblock %}

{% block body %}
<style>
    .test-container {
        max-width: 1200px;
        margin: 50px auto;
        padding: 0 20px;
    }
    .test-header {
        text-align: center;
        margin-bottom: 40px;
    }
    .test-header h1 {
        font-size: 2.5rem;
        color: #ff0033;
        text-transform: uppercase;
        letter-spacing: 2px;
    }
    .test-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 30px;
    }
    .card {
        background: #1a1a2e;
        border: 2px solid;
        border-radius: 15px;
        overflow: hidden;
        box-shadow: 0 10px 30px rgba(0,0,0,0.5);
    }
    .card.success-card {
        border-color: #00ff41;
    }
    .card.info-card {
        border-color: #00f3ff;
    }
    .card-header {
        padding: 20px;
        background: rgba(255,255,255,0.05);
        border-bottom: 1px solid rgba(255,255,255,0.1);
    }
    .card-header h3 {
        margin: 0;
        display: flex;
        align-items: center;
        gap: 10px;
    }
    .card-body {
        padding: 30px;
    }
    .form-group {
        margin-bottom: 20px;
    }
    .form-group label {
        display: block;
        margin-bottom: 8px;
        color: #00f3ff;
        font-weight: 600;
    }
    .form-control {
        width: 100%;
        padding: 12px;
        background: rgba(255,255,255,0.05);
        border: 2px solid rgba(255,0,51,0.3);
        border-radius: 8px;
        color: white;
        font-size: 1rem;
    }
    .form-control:focus {
        outline: none;
        border-color: #ff0033;
    }
    .btn {
        padding: 12px 30px;
        border: 2px solid;
        border-radius: 8px;
        font-weight: 700;
        text-transform: uppercase;
        cursor: pointer;
        transition: all 0.3s;
        font-size: 1rem;
    }
    .btn-primary {
        background: #00ff41;
        border-color: #00ff41;
        color: black;
    }
    .btn-primary:hover {
        background: transparent;
        color: #00ff41;
    }
    .btn-success {
        background: #00f3ff;
        border-color: #00f3ff;
        color: black;
    }
    .btn-success:hover {
        background: transparent;
        color: #00f3ff;
    }
    .response-area {
        background: #0a0a0f;
        border-radius: 8px;
        padding: 20px;
        min-height: 300px;
        color: #00ff41;
        font-family: 'Courier New', monospace;
        white-space: pre-wrap;
        border: 2px solid #00f3ff;
    }
    .quick-actions {
        display: flex;
        gap: 10px;
        margin-top: 20px;
        flex-wrap: wrap;
    }
    .endpoint {
        background: #0a0a0f;
        padding: 10px;
        border-radius: 5px;
        font-family: monospace;
        margin: 10px 0;
    }
</style>

<div class="test-container">
    <div class="test-header">
        <h1>🧪 TEST DE L'API DE PAIEMENT</h1>
        <p>Interface de test pour l'API Phantom Shop</p>
    </div>

    <div class="test-grid">
        <div class="card success-card">
            <div class="card-header">
                <h3><i class="fas fa-credit-card"></i> Nouveau paiement</h3>
            </div>
            <div class="card-body">
                <form id="paymentForm">
                    <div class="form-group">
                        <label>Email du client *</label>
                        <input type="email" class="form-control" id="customerEmail" value="client@test.com" required>
                    </div>
                    
                    <div class="form-group">
                        <label>Nom du client (optionnel)</label>
                        <input type="text" class="form-control" id="customerName" value="Jean Dupont">
                    </div>
                    
                    <div class="form-group">
                        <label>Montant (€) *</label>
                        <input type="number" step="0.01" class="form-control" id="amount" value="99.99" required>
                        <small style="color: #aaa;">Montant > 1000€ échoue automatiquement</small>
                    </div>
                    
                    <div class="form-group">
                        <label>Méthode de paiement *</label>
                        <select class="form-control" id="paymentMethod">
                            <option value="card">💳 Carte bancaire</option>
                            <option value="paypal">PayPal</option>
                            <option value="wallet">👛 Portefeuille</option>
                        </select>
                    </div>
                    
                    <div class="form-group">
                        <label>ShopItem ID (optionnel)</label>
                        <input type="number" class="form-control" id="shopItemId" value="">
                        <small style="color: #aaa;">ID de l'item à associer (optionnel)</small>
                    </div>
                    
                    <div class="quick-actions">
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-play"></i> Tester le paiement
                        </button>
                        <button type="button" class="btn btn-success" onclick="fillTestData()">
                            <i class="fas fa-magic"></i> Remplir test
                        </button>
                    </div>
                </form>
            </div>
        </div>

        <div class="card info-card">
            <div class="card-header">
                <h3><i class="fas fa-code"></i> Réponse API</h3>
            </div>
            <div class="card-body">
                <div class="response-area" id="response">
                    👆 Cliquez sur "Tester le paiement" pour voir la réponse...
                </div>
                
                <div style="margin-top: 20px;">
                    <div class="endpoint">POST /api/payments/process</div>
                    <div class="endpoint">GET /api/payments/list</div>
                    <div class="endpoint">GET /api/payments/{id}/status</div>
                </div>
                
                <div class="quick-actions">
                    <button class="btn btn-success" onclick="fetchPayments()">
                        <i class="fas fa-list"></i> Voir tous les paiements
                    </button>
                    <button class="btn btn-success" onclick="clearResponse()">
                        <i class="fas fa-trash"></i> Effacer
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
async function processPayment() {
    const data = {
        customerEmail: document.getElementById('customerEmail').value,
        customerName: document.getElementById('customerName').value || null,
        amount: parseFloat(document.getElementById('amount').value),
        paymentMethod: document.getElementById('paymentMethod').value
    };
    
    const shopItemId = document.getElementById('shopItemId').value;
    if (shopItemId) {
        data.shopItemId = parseInt(shopItemId);
    }
    
    document.getElementById('response').textContent = '⏳ Traitement en cours...';
    
    try {
        const response = await fetch('/api/payments/process', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
            },
            body: JSON.stringify(data)
        });
        
        const result = await response.json();
        document.getElementById('response').textContent = JSON.stringify(result, null, 2);
        
    } catch (error) {
        document.getElementById('response').textContent = '❌ Erreur: ' + error;
    }
}

async function fetchPayments() {
    document.getElementById('response').textContent = '⏳ Chargement...';
    
    try {
        const response = await fetch('/api/payments/list');
        const result = await response.json();
        document.getElementById('response').textContent = JSON.stringify(result, null, 2);
    } catch (error) {
        document.getElementById('response').textContent = '❌ Erreur: ' + error;
    }
}

function fillTestData() {
    document.getElementById('customerEmail').value = 'client@test.com';
    document.getElementById('customerName').value = 'Jean Dupont';
    document.getElementById('amount').value = '99.99';
    document.getElementById('paymentMethod').value = 'card';
    document.getElementById('shopItemId').value = '';
}

function clearResponse() {
    document.getElementById('response').textContent = '👆 Cliquez sur "Tester le paiement" pour voir la réponse...';
}

document.getElementById('paymentForm').addEventListener('submit', (e) => {
    e.preventDefault();
    processPayment();
});

// Remplir avec des données test au chargement
window.onload = fillTestData;
</script>
{% endblock %}