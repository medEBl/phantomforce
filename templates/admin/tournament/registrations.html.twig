{% extends 'base_back.html.twig' %}

{% block title %}Inscriptions : {{ tournament.name }} - ARENA Admin{% endblock %}

{% block body %}
<div class="admin-header d-flex justify-content-between align-items-center mb-4">
    <div>
        <div class="d-flex align-items-center gap-2 mb-1">
            <a href="{{ path('app_back_matchy_index') }}" class="btn-admin btn-admin-secondary p-1 px-2">
                <i class="fas fa-arrow-left"></i>
            </a>
            <h1 class="h3 mb-0">Inscriptions : {{ tournament.name }}</h1>
        </div>
        <p class="text-muted small mb-0">Liste des équipes inscrites pour ce tournoi ({{ registrations|length }} / {{ tournament.maxTeams }}).</p>
    </div>
</div>

<div class="admin-card p-0 overflow-hidden">
    <table class="admin-table mb-0">
        <thead>
            <tr>
                <th>Nom de l'équipe</th>
                <th>Email de contact</th>
                <th>Date d'inscription</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
            {% for registration in registrations %}
                <tr>
                    <td><div class="fw-bold">{{ registration.teamName }}</div></td>
                    <td>{{ registration.contactEmail }}</td>
                    <td><span class="text-muted small">{{ registration.createdAt|date('d/m/Y H:i') }}</span></td>
                    <td class="text-end">
                        <button class="btn-admin btn-admin-danger p-2" title="Supprimer (Non implémenté)">
                            <i class="fas fa-trash"></i>
                        </button>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="4" class="text-center py-5">
                        <i class="fas fa-users-slash mb-2 d-block opacity-25" style="font-size: 2rem;"></i>
                        <span class="text-muted">Aucune équipe inscrite pour le moment.</span>
                    </td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}
